# Optional proxy settings honoured by scrapers with --use-env-proxies.
# Leave blank unless you have a working proxy.
HTTP_PROXY=
HTTPS_PROXY=

# Alibaba-specific proxy for scraper_playwright.py persistent browser context.
ALIBABA_PROXY_SERVER=

# Path to exported browser cookies (Netscape format) for yt-dlp commands.
# Useful for age-restricted or premium content.
YTDLP_COOKIES_FILE=

# Optional: set a custom output directory shared by all scrapers.
# Each scraper also accepts --output-dir on the command line.
# SCRAPER_OUTPUT_DIR=
